# ── GitHub ────────────────────────────────────────────────────
# URL вашего форка репозитория. Jenkins использует его для SCM checkout.
GITHUB_REPO_URL=https://github.com/your_username/breast-cancer-classifier.git

# ── Docker Hub ────────────────────────────────────────────────
# Нужно для push образов в CI/CD pipeline.
# Без реального аккаунта оставьте как есть — локальная сборка работает.
DOCKERHUB_USER=your_dockerhub_username
DOCKERHUB_PASS=your_dockerhub_password

# ── Jenkins ───────────────────────────────────────────────────
# Пароль admin-пользователя Jenkins UI (http://localhost:8080)
# По умолчанию "admin" — менять по желанию.
JENKINS_ADMIN_PASSWORD=admin

# ── PostgreSQL (v2.0+; в v3.0 переезжает в Vault) ────────────
# DB_PASSWORD=changeme
